// Arithmetic Exception
//Exmaple :1
package p1;
public class A{
	public static void main(String[] args) {
		try {
			int x = 10;
			int y = 0;
			int z = x/y;
			System.out.println(z);
		} catch (ArithmeticException e) {
			e.printStackTrace();
		}
		System.out.println("i love java ");
	}
}
